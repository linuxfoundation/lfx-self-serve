      "template": "<Section style=\"padding:0 15px\">\n  <Text if=\"section_title\" style=\"margin:0 0 4px;font-size:12px;color:#4086c6;font-weight:bold;text-transform:uppercase\">{{section_title}}</Text>\n  <Heading if=\"title\" class=\"brick-title\">{{title}}</Heading>\n  <richtext field=\"description\" class=\"body\" />\n  <Text if=\"link\" class=\"body\" style=\"margin-top:8px\">\n    <strong><Link href=\"{{link}}\" class=\"link\">{{link_text}}</Link></strong>\n  </Text>\n  <Hr class=\"divider\" />\n</Section>"
    },
