      "template": "<Section class=\"card\">\n  <div style=\"padding:15px 15px 10px\">\n    <Text if=\"heading\" class=\"eyebrow\">{{heading}}</Text>\n    <Heading if=\"title\" class=\"title\">{{title}}</Heading>\n    <richtext field=\"body\" class=\"body\" />\n    <div if=\"useful_links\">\n      <Hr style=\"border:0;border-top:1px solid #bbb;margin:16px 0\" />\n      <Heading style=\"margin:0 0 8px;font-size:24px;font-weight:bold;color:#000\">Useful links</Heading>\n      <Text each=\"useful_links\" class=\"body\" style=\"margin:0 0 12px\">\n        <strong><Link href=\"{{url}}\" class=\"link\">{{title}}</Link></strong> {{description}}\n      </Text>\n    </div>\n  </div>\n</Section>"
    },
    {
      "block_type": "generic_section",
      "label": "Generic Section",
