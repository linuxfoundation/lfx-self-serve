      "template": "<Section class=\"card\">\n  <div style=\"padding:15px 15px 5px\">\n    <Text class=\"eyebrow\">HOT TAKE</Text>\n    <Heading if=\"title\" class=\"title\">{{title}}</Heading>\n    <richtext field=\"body\" class=\"body\" />\n  </div>\n  <Section if=\"poll_option_1_label\">\n    <div style=\"padding:0 5px 15px\">\n      <Row>\n        <Column style=\"width:50%;text-align:center;padding:5px\">\n          <Button href=\"{{poll_option_1_link}}\" style=\"background-color:#4086c6;color:#ffffff;font-weight:bold;padding:10px 18px;border-radius:6px;text-decoration:none\">{{poll_option_1_label}}</Button>\n        </Column>\n        <Column if=\"poll_option_2_label\" style=\"width:50%;text-align:center;padding:5px\">\n          <Button href=\"{{poll_option_2_link}}\" style=\"background-color:#4086c6;color:#ffffff;font-weight:bold;padding:10px 18px;border-radius:6px;text-decoration:none\">{{poll_option_2_label}}</Button>\n        </Column>\n      </Row>\n    </div>\n  </Section>\n</Section>"
