      "template": "<Section style=\"background-color:#d7d7d7;border-collapse:separate;border-radius:15px;width:650px;max-width:650px;margin:0 auto 20px;color:#000\">\n  <div style=\"padding:15px\">\n    <Text class=\"eyebrow\">{{header_title}}</Text>\n    <div each=\"jobs\" style=\"margin:0 0 16px\">\n      <Text style=\"margin:0 0 10px 0;font-size:18px;font-weight:bold;color:#000\"><Link href=\"{{apply_link}}\" class=\"link\">{{job_title}}</Link> // {{company}} // {{location}}</Text>\n      <richtext field=\"description\" class=\"body\" />\n    </div>\n  </div>\n</Section>"
    },
