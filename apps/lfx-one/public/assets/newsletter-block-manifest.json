      "template": "<Section class=\"card\">\n  <div style=\"padding:15px 15px 5px\">\n    <Text class=\"eyebrow\" style=\"text-transform:uppercase\">PRESENTED BY {{sponsor_name}}</Text>\n    <Heading if=\"headline\" style=\"margin:0 0 10px;font-size:23px;font-weight:bold;color:#555;line-height:1.2\">{{headline}}</Heading>\n    <Link if=\"image_url\" href=\"{{image_link}}\"><Img src=\"{{image_url}}\" alt=\"\" style=\"display:block;width:100%;max-width:100%;height:auto;border:0\" /></Link>\n    <richtext field=\"body\" class=\"body\" />\n    <Text if=\"cta_text\" class=\"body\" style=\"margin-top:12px\"><strong><Link href=\"{{cta_link}}\" class=\"link\">{{cta_text}}</Link></strong></Text>\n  </div>\n</Section>"
    }
  ],
  "wrapper": "<Section>\n  <div style=\"padding: 15px 0\">\n    <Text style=\"margin: 0; text-align: center; font-size: 16px; color: #4086c6\">\n      <span if=\"edition.view_online_link\">\n        <Link href=\"{{edition.view_online_link}}\" style=\"color: #4086c6; text-decoration: underline\">View Online</Link>\n      </span>\n    </Text>\n    <Text if=\"edition.date\" style=\"margin: 8px 0 0; text-align: center; font-size: 14px; color: #4086c6\">\n      {{edition.date}}\n    </Text>\n    <Text style=\"margin: 8px 0 0; text-align: center; font-size: 12px; color: #4086c6\">\n      Forwarded this email?\n      <Link href=\"https://aaif.live/newsletters/usercommunity/\" style=\"color: #4086c6; text-decoration: underline\">\n        Subscribe here\n      </Link>\n    </Text>\n  </div>\n</Section>\n\n<slot name=\"body\" />\n\n<Section>\n  <div style=\"padding: 15px 0\">\n    <Text if=\"edition.unsubscribe_url\" style=\"margin: 0; text-align: center; font-size: 12px; color: #999\">\n      <Link href=\"{{edition.unsubscribe_url}}\" style=\"color: #999; text-decoration: underline\">Unsubscribe</Link>\n      &middot;\n      <Link href=\"{{edition.manage_subscriptions_url}}\" style=\"color: #999; text-decoration: underline\">Manage your email preferences</Link>\n    </Text>\n  </div>\n</Section>",
  "source": {
