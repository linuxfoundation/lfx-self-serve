      "template": "<Section style=\"padding:0 15px\">\n  <Heading if=\"title\" class=\"brick-title\">{{title}}</Heading>\n  <richtext field=\"description\" class=\"body\" />\n  <Text class=\"body\" style=\"margin-top:8px\">\n    <strong>\n      <Link if=\"video_link\" href=\"{{video_link}}\" class=\"link\">Video</Link>\n      <span if=\"spotify_link\"> &middot; <Link href=\"{{spotify_link}}\" class=\"link\">Spotify</Link></span>\n      <span if=\"apple_link\"> &middot; <Link href=\"{{apple_link}}\" class=\"link\">Apple</Link></span>\n    </strong>\n  </Text>\n  <Hr class=\"divider\" />\n</Section>"
