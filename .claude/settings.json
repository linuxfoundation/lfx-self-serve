{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-protected-files.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "lfx-skills": {
      "source": {
        "source": "github",
        "repo": "linuxfoundation/lfx-skills"
      }
    }
  },
  "enabledPlugins": {
    "lfx-skills@lfx-skills": true
  }
}
